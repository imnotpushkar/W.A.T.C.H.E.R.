# ============================================================
# WATCHER — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git. This file (.env.example) is safe to commit.
# ============================================================

# --- Ollama (Local LLM) ---
# The URL where Ollama is running. Default is localhost port 11434.
OLLAMA_URL=http://localhost:11434

# The model Ollama will use. Must be pulled first: ollama pull llama3.1:8b
OLLAMA_MODEL=llama3.1:8b

# How many tokens Ollama generates per response. 512 is fast + sufficient for suggestions.
OLLAMA_MAX_TOKENS=512

# Temperature controls creativity. 0.0 = deterministic, 1.0 = very creative.
OLLAMA_TEMPERATURE=0.7

# --- Hotkey ---
# The keyboard shortcut that triggers Watcher.
# Format follows pynput conventions: ctrl+space, ctrl+shift+w, etc.
WATCHER_HOTKEY=ctrl+space

# --- Overlay ---
# Opacity of the suggestion overlay. 0.0 = invisible, 1.0 = fully opaque.
OVERLAY_OPACITY=0.92

# How long (ms) the overlay stays before auto-dismissing. 0 = never dismiss.
OVERLAY_TIMEOUT_MS=8000

# --- Voice Output ---
# TTS engine. Options: edge-tts (online, high quality) | pyttsx3 (offline, lower quality)
TTS_ENGINE=edge-tts

# Voice name for edge-tts. Run `edge-tts --list-voices` to see all options.
TTS_VOICE=en-IN-NeerjaNeural

# TTS volume. 0.0 to 1.0.
TTS_VOLUME=0.9

# --- Screen Reader ---
# Seconds uiautomation waits for a UI element before giving up.
SCREEN_READ_TIMEOUT=3

# Max characters to read from screen. Keeps Ollama prompts from being too long.
SCREEN_READ_MAX_CHARS=4000

# --- Typing ---
# Delay between each character Watcher types (seconds). 0.02 = 20ms per char.
TYPIST_CHAR_DELAY=0.02

# --- Logging ---
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# Log file path relative to project root.
LOG_FILE=data/watcher.log

# --- Data Paths ---
# SQLite database file path.
DB_PATH=data/watcher.db

# ChromaDB vector store folder path.
CHROMA_PATH=data/chroma
